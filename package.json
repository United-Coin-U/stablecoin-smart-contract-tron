  "license": "MIT",
  "description": "",
  "dependencies": {
    "@openzeppelin/contracts": "^5.4.0",
    "@openzeppelin/contracts-upgradeable": "^5.4.0",
    "axios": "^1.13.2",
    "dotenv": "^17.2.3",
    "tronweb": "^6.0.4"
  }
}
